# --- Google Gemini ---
# Required. Server-side only key. NEVER prefix with NEXT_PUBLIC_ or it will
# be exposed in the browser bundle. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Overrides the default model (gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash

# Optional. Requests allowed per IP inside the rate-limit window.
RATE_LIMIT_MAX=10

# Optional. Rate-limit window in milliseconds (default 60000 = 1 minute).
RATE_LIMIT_WINDOW_MS=60000
